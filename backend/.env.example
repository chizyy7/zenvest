# ============================================================
# Zenvest Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# OpenAI (for AI chat — optional, falls back to rule-based)
OPENAI_API_KEY=sk-...

# Paystack (payment processing)
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# Alpha Vantage (stock prices — optional)
ALPHA_VANTAGE_API_KEY=your-api-key

# CoinGecko (crypto prices — free, no key needed)
# COINGECKO_API_URL=https://api.coingecko.com/api/v3

# n8n (email automation — optional)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/...
N8N_WEEKLY_REPORT_WEBHOOK=https://your-n8n-instance.com/webhook/...

# Server
PORT=8000
ENVIRONMENT=development  # development | production
